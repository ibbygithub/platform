# ── Required ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=REPLACE_ME
ALLOWED_USER_IDS=123456789          # comma-separated Telegram numeric user IDs
UPSTREAM_URL=http://YOUR_UPSTREAM_HOST/telegram/events

# ── Mode ──────────────────────────────────────────────────────────────────────
# polling  → bot connects out to Telegram (works on LAN, no public IP needed)
# webhook  → Telegram calls your HTTPS URL  (requires public domain + TLS)
TELEGRAM_MODE=polling

# Webhook settings (only used when TELEGRAM_MODE=webhook)
# WEBHOOK_DOMAIN=https://telegram.platform.ibbytech.com
# WEBHOOK_PATH=/webhook
# WEBHOOK_PORT=3000

# ── Outbound Send API ─────────────────────────────────────────────────────────
# Shared secret for POST /send — callers must send X-Send-Secret: <value>
# Leave empty to disable auth (dev only — not recommended in production)
SEND_SECRET=REPLACE_ME_WITH_RANDOM_SECRET
SEND_API_PORT=3001

# ── Optional ──────────────────────────────────────────────────────────────────
ALLOWED_GROUP_IDS=                  # comma-separated group IDs (leave blank for DM-only)
UPSTREAM_TIMEOUT_MS=30000

# Capability flags forwarded in every event envelope
CAP_CAN_SEARCH=false
CAP_CAN_SCRAPE=false
CAP_CAN_FETCH_FILES=false
