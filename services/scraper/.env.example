# ── Firecrawl self-hosted ─────────────────────────────────────────────────────
# Set your own API key — this is what callers pass to scraper-api,
# and scraper-api forwards it to the Firecrawl container.
FIRECRAWL_API_KEY=REPLACE_WITH_YOUR_OWN_KEY

# Optional: OpenAI key for Firecrawl's LLM-based extraction features
# Leave blank to disable AI extraction (basic scraping still works without it)
OPENAI_API_KEY=

# ── Internal routing (set automatically by docker-compose) ───────────────────
# FIRECRAWL_URL is injected as an environment override in docker-compose.yml
# Do not set it here unless you are running scraper-api standalone.
# FIRECRAWL_URL=http://firecrawl-api:3002
