# .env.test.example — copy to .env.test and fill in real values
#
# Usage:
#   cp .env.test.example .env.test
#   # Fill in PGPASSWORD and FIRECRAWL_API_KEY
#
#   # Linux / Mac:
#   set -a; source .env.test; set +a
#   python validate_firecrawl.py
#
#   # Windows PowerShell:
#   Get-Content .env.test | ForEach-Object { if ($_ -notmatch '^#' -and $_ -match '=') { $k,$v = $_ -split '=',2; [System.Environment]::SetEnvironmentVariable($k,$v) } }
#   python validate_firecrawl.py

# ── Scraper API ───────────────────────────────────────────────────────────────
# URL of the platform scraper API.
# From svcnode-01 or brainnode-01: use the FQDN below (routed through Traefik).
# From inside svcnode-01 directly: http://localhost:8083
SCRAPER_URL=https://scrape.platform.ibbytech.com

# Direct URL to the self-hosted Firecrawl instance (used for connectivity check
# in Step 0 and for any direct calls that bypass the scraper wrapper).
# svcnode-01 (192.168.71.220) exposes Firecrawl on port 3002.
FIRECRAWL_API_URL=http://192.168.71.220:3002

# API key sent to the scraper wrapper.
# Self-hosted Firecrawl has USE_DB_AUTHENTICATION=false — any non-empty string works.
FIRECRAWL_API_KEY=local-no-auth

# ── PostgreSQL (dbnode-01) ────────────────────────────────────────────────────
PGHOST=dbnode-01
PGPORT=5432
PGDATABASE=platform_v1

# Must be a role with CREATE SCHEMA + CREATE TABLE privilege on platform_v1,
# or have those objects pre-created and GRANT'd (see schema.sql comments).
# A superuser or the platform admin role works for first-run schema creation.
PGUSER=scraper_app
PGPASSWORD=REPLACE_ME
