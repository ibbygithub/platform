# ── Tavily Platform Gateway — Environment Variables ──────────────────────────
# Copy this file to .env and fill in the values below.
# The .env file is created DIRECTLY ON THE NODE — never committed to git.
#
# Tavily account: https://app.tavily.com
# Use the standard API key (NOT the MCP key).

# ── Tavily API Key ────────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-REPLACE_ME

# ── Loki ─────────────────────────────────────────────────────────────────────
LOKI_URL=http://192.168.71.220:3100
