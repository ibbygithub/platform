# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=REPLACE_ME
OPENAI_BASE_URL=https://api.openai.com/v1
# Override base URL for OpenAI-compatible proxies (LiteLLM, LocalAI, etc.)

# ── Google Gemini ─────────────────────────────────────────────────────────────
GOOGLE_API_KEY=REPLACE_ME
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com

# ── Anthropic Claude ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=REPLACE_ME
ANTHROPIC_BASE_URL=https://api.anthropic.com

# ── Defaults (used when provider/model not specified in request) ──────────────
DEFAULT_EMBED_PROVIDER=openai
DEFAULT_EMBED_MODEL=text-embedding-3-small

DEFAULT_CHAT_PROVIDER=google
DEFAULT_CHAT_MODEL=gemini-2.0-flash

# ── Available models reference ────────────────────────────────────────────────
# OpenAI chat:       gpt-4o, gpt-4o-mini, o1-mini
# OpenAI embed:      text-embedding-3-small, text-embedding-3-large
# Google chat:       gemini-2.0-flash, gemini-2.0-pro
# Google embed:      text-embedding-004, embedding-001
# Anthropic chat:    claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5-20251001
# Anthropic embed:   (not supported)
