# platform/infra/compose — environment variables
# Copy this file to .env and fill in the values.
# This file is safe to commit. Never commit .env itself.

# ── Postgres ────────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=REPLACE_ME

# ── Cloudflare Tunnel ───────────────────────────────────────────────────────────
# Obtain from: Cloudflare Zero Trust → Networks → Tunnels → shogun-laptop → Docker connector
# Paste the full token value (long string after --token in the docker run command shown)
TUNNEL_TOKEN=REPLACE_ME
