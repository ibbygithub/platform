# IbbyTech Platform — Environment Variables
#
# Copy this file to .env in the relevant service directory and fill in values.
# NEVER commit .env files. This file is the only committed reference.
#
# Each service reads its own .env from its own directory on the node.
# Deploy path on svcnode-01: /opt/git/work/platform/services/<service>/.env

# ── Tavily Gateway (services/tavily/) ─────────────────────────────────────────
# Standard API key from app.tavily.com. NOT the MCP key variant.
TAVILY_API_KEY=tvly-REPLACE_ME
