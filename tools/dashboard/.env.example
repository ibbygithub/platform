# IbbyTech Platform MVP Dashboard -- required environment variables
# Copy this file to .env and fill in values before running.
# No API keys are needed here -- all provider keys live in the gateway container.

LLM_GATEWAY_URL=https://llm.platform.ibbytech.com
SCRAPER_URL=http://scrape.platform.ibbytech.com
PLACES_URL=http://places.platform.ibbytech.com
TELEGRAM_URL=http://telegram.platform.ibbytech.com
